{
  "rules": {
    "votes": {
      ".read": true,
      "$player": {
        ".write": true,
        ".validate": "newData.hasChildren(['name', 'games', 'ts']) && newData.child('name').isString() && newData.child('ts').isNumber()"
      }
    },
    "availability": {
      ".read": true,
      "$player": {
        ".write": true,
        ".validate": "newData.hasChildren(['name', 'dates', 'ts']) && newData.child('name').isString() && newData.child('ts').isNumber()"
      }
    },
    "customGames": {
      ".read": true,
      ".write": true
    }
  }
}
